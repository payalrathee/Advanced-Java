<!DOCTYPE web-app PUBLIC
 "-//Sun Microsystems, Inc.//DTD Web Application 2.3//EN"
 "http://java.sun.com/dtd/web-app_2_3.dtd" >

<web-app>
  <display-name>Archetype Created Web Application</display-name>
  <servlet>
  	<servlet-name>SignUpServlet</servlet-name>
  	<display-name>SignUpServlet</display-name>
  	<description></description>
  	<servlet-class>servlets.SignUpServlet</servlet-class>
  </servlet>
  <servlet>
  	<servlet-name>SignInServlet</servlet-name>
  	<display-name>SignInServlet</display-name>
  	<description></description>
  	<servlet-class>servlets.SignInServlet</servlet-class>
  </servlet>
  <servlet>
  	<servlet-name>SignOutServlet</servlet-name>
  	<display-name>SignOutServlet</display-name>
  	<description></description>
  	<servlet-class>servlets.SignOutServlet</servlet-class>
  </servlet>
  <servlet>
  	<servlet-name>DisplayQuestionServlet</servlet-name>
  	<display-name>DisplayQuestionServlet</display-name>
  	<description></description>
  	<servlet-class>servlets.DisplayQuestionServlet</servlet-class>
  </servlet>
  <servlet>
  	<servlet-name>EvaluateServlet</servlet-name>
  	<display-name>EvaluateServlet</display-name>
  	<description></description>
  	<servlet-class>servlets.EvaluateServlet</servlet-class>
  </servlet>
  <servlet-mapping>
  	<servlet-name>SignUpServlet</servlet-name>
  	<url-pattern>/SignUpServlet</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
  	<servlet-name>SignInServlet</servlet-name>
  	<url-pattern>/SignInServlet</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
  	<servlet-name>SignOutServlet</servlet-name>
  	<url-pattern>/SignOutServlet</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
  	<servlet-name>DisplayQuestionServlet</servlet-name>
  	<url-pattern>/DisplayQuestionServlet</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
  	<servlet-name>EvaluateServlet</servlet-name>
  	<url-pattern>/EvaluateServlet</url-pattern>
  </servlet-mapping>
</web-app>
